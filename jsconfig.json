{
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "paths": {
            "#components": ["src/components"],
            "#components/*": ["src/components/*"],
            "#constants": ["src/constants.js"],
            "#store": ["src/store"],
            "#store/*": ["src/store/*"],
            "#hoc": ["src/hoc"],
            "#hoc/*": ["src/hoc/*"],
            "#windows": ["src/windows"],
            "#windows/*": ["src/windows/*"]
        }
    },
    "include": ["src"]
}
